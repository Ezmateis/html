*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body{
    height: 200vh;
    width: 200vh;
    display: flex;
    justify-content: center;
    align-items: center;
}

div{
    border: 10px groove rgb(44, 255, 209);
    width: 10%;
}

.conteudo{
    width: 30%;
    height: 30%;
    padding: 10px; 
    justify-content: center;
    align-items: center;
    display: flex;
}

.div2{
    flex: 2;
}   

